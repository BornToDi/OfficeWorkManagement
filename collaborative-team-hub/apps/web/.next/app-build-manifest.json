{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/dashboard/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/dashboard/page.js"
    ],
    "/chat/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/chat/page.js"
    ],
    "/workspaces/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/workspaces/page.js"
    ],
    "/(workspace)/announcements/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(workspace)/announcements/page.css",
      "static/chunks/app/(workspace)/announcements/page.js"
    ],
    "/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/not-found.js"
